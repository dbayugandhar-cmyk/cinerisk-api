# CINEOS Theater Deployment Configuration
# Copy this to .env and fill in your values

# Theater identity
THEATER_NAME=Alamo Drafthouse NYC
CINEOS_API_KEY=cineos-prod-2026-secure-key
DATABASE_URL=postgresql://postgres:PASSWORD@tramway.proxy.rlwy.net:27075/railway

# Film titles per screen
FILM_TITLE=Mandalorian Grogu
FILM_TITLE_2=Thunderbolts
FILM_TITLE_3=Sinners

# RTSP stream URLs per screen
# Format: rtsp://username:password@ip:port/stream
# Leave as 0,1,2 for webcam testing
SCREEN_1_RTSP=rtsp://admin:password@192.168.1.101:554/stream1
SCREEN_2_RTSP=rtsp://admin:password@192.168.1.102:554/stream1
SCREEN_3_RTSP=rtsp://admin:password@192.168.1.103:554/stream1
